#!/usr/bin/env perl
use Modern::Perl '2018';

use FindBin;
use lib "$FindBin::Bin/../lib";

use Getopt::Long;
use Fcntl ':flock';
use File::Basename qw(basename);
use Burbleboy::Config qw(read_config config_defaults home_dir);
use Burbleboy::Publish qw(:all);

use Template;
use File::Spec;

our $VERSION = '1.0';

Main();
exit;

sub Main {
    my %opts;
    GetOptions(
        'publish-all'        => \$opts{ publish_all },
        'publish-new'        => \$opts{ publish_new },
        'publish-only-posts' => \$opts{ publish_only_posts },
        'publish-only-notes' => \$opts{ publish_only_notes },
        'init'               => \$opts{ init },
        'show-conf'          => \$opts{ show_conf },
        'force'              => \$opts{ force },
        'dryrun'             => \$opts{ dryrun },
        'v|verbose'          => \$opts{ verbose },
        'h|help'             => \$opts{ help },
        'version'            => \$opts{ version },
    ) or do { warn "Try --help for usage.\n"; exit 1; };

    if ( $opts{ help } )   { print usage_text();    exit 0; }
    if ( $opts{ version } ) { print version_text();  exit 0; }

    my $config_file = home_dir() . '/.burbleboy.conf';

    if ( $opts{ show_conf } ) {
        _show_config( $config_file, $opts{ verbose } );
        exit 0;
    }

    if ( $opts{ init } ) {
        _init_config( $config_file, $opts{ verbose } );
        exit 0;
    }

    my $has_action = $opts{ publish_all } || $opts{ publish_new }
        || $opts{ publish_only_posts } || $opts{ publish_only_notes };

    unless ($has_action) {
        print usage_text();
        exit 0;
    }

    my $config = read_config( $config_file );

    my $lock_fh;
    $lock_fh = get_lock( $config ) unless $opts{ dryrun };
    my $tt = _setup_template();

    my $source_dir = $config->{ source_directory } || $config->{ path };
    die "Source directory not found: $source_dir" unless -d $source_dir;

    my $pub_dir = $config->{ publication_directory }
        || $config->{ publication_path }
        || '.';

    my $do_posts;
    my $do_notes;

    if ( $opts{ publish_new } ) {
        $do_posts = !$opts{ publish_only_notes };
        $do_notes = !$opts{ publish_only_posts };
    } else {
        $do_posts = $opts{ publish_all } || $opts{ publish_only_posts }
            || ( !$opts{ publish_only_posts } && !$opts{ publish_only_notes } );
        $do_notes = $opts{ publish_all } || $opts{ publish_only_notes };
    }

    my $posts = [];
    my $notes = [];

    if ( $do_posts ) {
        if ( $opts{ publish_new } ) {
            $posts = incremental_publish_posts( $config, $tt, $source_dir,
                $opts{ force }, $opts{ verbose }, $opts{ dryrun } );
        } else {
            $posts = _publish_posts( $config, $tt, $source_dir,
                $opts{ force }, $opts{ verbose }, $opts{ dryrun } );
        }
    }

    if ( $do_notes ) {
        my $notes_dir = $config->{ source_notes_directory }
            || "$source_dir/notes";
        if ( $opts{ publish_new } ) {
            $notes = incremental_publish_notes( $config, $tt, $notes_dir,
                $opts{ force }, $opts{ verbose }, $opts{ dryrun } );
        } else {
            $notes = _publish_notes( $config, $tt, $source_dir,
                $opts{ force }, $opts{ verbose }, $opts{ dryrun } );
        }
    }

    if ( $opts{ dryrun } ) {
        my @pages;
        push @pages, 'blog.html' if $do_posts;
        push @pages, 'archive.html' if $do_posts;
        push @pages, 'tags.html' if $do_posts || $do_notes;
        push @pages, 'atom.xml' if $do_posts;
        push @pages, 'feed.json' if $do_posts;
        push @pages, 'notes_roll.html' if $do_notes;
        push @pages, 'recent_notes.json' if $do_notes;
        push @pages, 'css/site.css' if $do_posts || $do_notes;
        push @pages, 'js/site.js' if $do_posts || $do_notes;
        say "(dryrun) Would regenerate: " . join( ', ', @pages ) if @pages;
    } else {
        publish_site_css( $config, $tt );
        publish_site_js( $config, $tt );
        if ( $do_posts ) {
            if ( $opts{ publish_new } ) {
                if ( @$posts ) {
                    my $all_posts = read_all_meta( $config, 'post' );
                    if ( @$all_posts ) {
                        fill_body_for_top_n( $all_posts, $pub_dir,
                            $config->{ show_max_posts } || 5 );
                        publish_front_page( $config, $tt, $all_posts );

                        publish_archive_page( $config, $tt, $all_posts );
                        publish_tags_index( $config, $tt, $all_posts, read_all_meta($config, 'note') );

                        fill_body_for_posts( $all_posts, $pub_dir );
                        publish_atom_feed( $config, $tt, $all_posts );
                        publish_json_feed( $config, $tt, $all_posts );
                    } else {
                        warn "No meta files found. Run --publish-all first.\n"
                            if $opts{ verbose };
                        publish_front_page( $config, $tt, $posts );
                        publish_archive_page( $config, $tt, $posts );
                        publish_tags_index( $config, $tt, $posts, $notes );
                        publish_atom_feed( $config, $tt, $posts );
                        publish_json_feed( $config, $tt, $posts );
                    }
                } else {
                    publish_tags_index( $config, $tt, [], $notes );
                }
            } else {
                publish_front_page( $config, $tt, $posts );
                publish_archive_page( $config, $tt, $posts );
                publish_tags_index( $config, $tt, $posts, $notes );
                publish_atom_feed( $config, $tt, $posts );
                publish_json_feed( $config, $tt, $posts );
            }
        }

        if ( $do_notes ) {
            if ( $opts{ publish_new } ) {
                if ( @$notes ) {
                    my $all_notes = read_all_meta( $config, 'note' );
                    if ( @$all_notes ) {
                        fill_body_for_posts( $all_notes, $pub_dir );
                        publish_notes_roll( $config, $tt, $all_notes );
                        publish_notes_json( $config, $tt, $all_notes );
                    } else {
                        warn "No note meta files found. Run --publish-all first.\n"
                            if $opts{ verbose };
                        publish_notes_roll( $config, $tt, $notes );
                        publish_notes_json( $config, $tt, $notes );
                    }
                } elsif ( $opts{ verbose } ) {
                    say "No new notes; skipping roll regeneration.";
                }
            } else {
                publish_notes_roll( $config, $tt, $notes );
                publish_notes_json( $config, $tt, $notes );
            }
        }
    }

    free_lock( $lock_fh ) if $lock_fh;
    exit 0;
}

sub usage_text {
    return <<'EOT';
burbleboycmd - manage burbleboy sites

USAGE:

    burbleboycmd [OPTIONS]

GETTING STARTED:

    burbleboycmd --init                      # first run: create config + dirs
    burbleboycmd --publish-all               # full site rebuild
    burbleboycmd --publish-new               # incremental (changed files only)

COMMANDS:

--init                   Create ~/.burbleboy.conf and project directories
                         (prompts before overwriting existing config)
--show-conf              Display current configuration (from file or defaults)
--publish-all            Republish all known source files
--publish-new            Incremental publish (only changed files)
--publish-only-posts     Publish only new posts; ignore new notes
--publish-only-notes     Publish only new notes; ignore new posts

OPTIONS:

--force                  Force publication even if source unchanged
--dryrun                 Show what would be done without writing files
--v|verbose              Enable verbose messages
--version                Print version number
--h|help                 This screen

EOT
}

sub version_text {
    return "burbleboy/taskboy3000 v$VERSION\n";
}

sub _setup_template {
    return Template->new(
        {   INCLUDE_PATH => "$FindBin::Bin/../lib/Burbleboy/Template",
            ENCODING     => 'utf8',
            ABSOLUTE     => 1,
            RELATIVE     => 1,
        }
    );
}

sub _publish_posts {
    my ( $config, $tt, $source_dir, $force, $verbose, $dryrun ) = @_;

    opendir my $dh, $source_dir or die "Cannot read $source_dir: $!";
    my @files = grep { /\.(?:md|markdown)$/i && -f "$source_dir/$_" }
        readdir( $dh );
    closedir $dh;

    my @posts;
    for my $file ( @files ) {
        next if $file =~ /^\./;
        my $source_file = "$source_dir/$file";
        if ( $dryrun ) {
            say "(dryrun) Would publish: $file";
            next;
        }
        my $post = eval { publish_post( $source_file, $config, $tt ) };
        if ( $@ ) {
            warn "Error publishing $file: $@" if $verbose;
            next;
        }
        push @posts, $post;
        say "Published: $file" if $verbose;
    }

    return \@posts;
}

sub _publish_notes {
    my ( $config, $tt, $source_dir, $force, $verbose, $dryrun ) = @_;

    my $notes_dir = $config->{ source_notes_directory }
        || "$source_dir/notes";
    return [] unless -d $notes_dir;

    opendir my $dh, $notes_dir or die "Cannot read $notes_dir: $!";
    my @files = grep { /\.(?:txt|md|markdown)$/i && -f "$notes_dir/$_" }
        readdir( $dh );
    closedir $dh;

    my @notes;
    for my $file ( @files ) {
        next if $file =~ /^\./;
        my $source_file = "$notes_dir/$file";
        if ( $dryrun ) {
            say "(dryrun) Would publish note: $file";
            next;
        }
        my $note = eval { publish_note( $source_file, $config, $tt ) };
        if ( $@ ) {
            warn "Error publishing note $file: $@" if $verbose;
            next;
        }
        push @notes, $note;
        say "Published note: $file" if $verbose;
    }

    return \@notes;
}

sub _init_config {
    my ( $config_file, $verbose ) = @_;

    if ( -f $config_file ) {
        print "Config file '$config_file' already exists. Overwrite? [y/N] ";
        my $answer = <STDIN>;
        chomp $answer;
        return unless lc( $answer ) eq 'y' || lc( $answer ) eq 'yes';
    }

    require YAML::XS;
    require File::Path;
    my $defaults = Burbleboy::Config::config_defaults();
    my $home     = home_dir();
    my $config   = {
        base_uri         => $defaults->{ base_uri },
        title            => $defaults->{ title },
        author_name      => $defaults->{ author_name },
        author_email     => $defaults->{ author_email },
        source_path      => "$home/burbleboy/source",
        publication_path => "$home/burbleboy/docroot",
        show_max_posts   => $defaults->{ show_max_posts },
    };

    File::Path::mkpath( $config->{ source_path } );
    File::Path::mkpath( $config->{ publication_path } );
    YAML::XS::DumpFile( $config_file, $config );
    say "Created $config_file with defaults." if $verbose;
}

sub _show_config {
    my ( $config_file, $verbose ) = @_;

    my $config;
    if ( -f $config_file ) {
        say "# Configuration from: $config_file";
        require YAML::XS;
        $config = YAML::XS::LoadFile( $config_file );
    } else {
        say "# No configuration file found at: $config_file";
        say "# Showing default values.";
        say "# Run with --init to create a configuration.";
        $config = {};
    }

    my $defaults = Burbleboy::Config::config_defaults();
    for my $key ( keys %$defaults ) {
        $config->{ $key } //= $defaults->{ $key };
    }

    my $home = home_dir();
    $config->{ source_path }      //= "$home/burbleboy/source";
    $config->{ publication_path } //= "$home/burbleboy/docroot";

    my @keys = qw(base_uri title author_name author_email source_path
        source_notes_path publication_path show_max_posts site_description
        enable_replies);
    for my $key (@keys) {
        next unless exists $config->{ $key };
        my $val = $config->{ $key };
        next if ref $val;
        printf "%-22s %s\n", "$key:", $val;
    }
}

sub get_lock {
    my ($config) = @_;
    my $pub_dir = $config->{ publication_directory }
        || $config->{ publication_path }
        || home_dir()
        || '/tmp';
    my $lock_file = "$pub_dir/.burbleboycmd.lock";
    open my $fh, '>', $lock_file or die "Cannot create lock file: $!";
    flock( $fh, LOCK_EX | LOCK_NB )
        or die "Cannot obtain lock. Try back later.\n";
    return $fh;
}

sub free_lock {
    my ( $fh ) = @_;
    flock( $fh, LOCK_UN );
    close( $fh );
}
